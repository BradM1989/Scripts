#!/bin/sh /etc/rc.common

START=79
STOP=11

EXTRA_COMMANDS="backup restore"
EXTRA_HELP="    backup  backup current rrd database"

RRD_DIR="/tmp/rrd"
BACKUP_DIR="/root/statistics_backup"
BACKUP_FILE="rrdbackup.tgz"
LOGFILE="/root/logs/rrdbackup.log"

backup() {
    [ ! -d "$RRD_DIR" ] && return 0

    TIMESTAMP="$(date '+%Y-%m-%d %H:%M')"
    TMP_FILE="$(mktemp /tmp/rrdbackup.XXXXXX)"

    mkdir -p "$BACKUP_DIR"
    mkdir -p "$(dirname "$LOGFILE")"

    echo "[$TIMESTAMP] Backing up RRD to $BACKUP_DIR/$BACKUP_FILE" >> "$LOGFILE"

    tar -czf "$TMP_FILE" -C / tmp/rrd

    mv "$TMP_FILE" "$BACKUP_DIR/$BACKUP_FILE"
}

restore() {
    TIMESTAMP="$(date '+%Y-%m-%d %H:%M')"
    mkdir -p "$(dirname "$LOGFILE")"

    if [ -f "$BACKUP_DIR/$BACKUP_FILE" ]; then
        echo "[$TIMESTAMP] Restoring RRD from $BACKUP_DIR/$BACKUP_FILE" >> "$LOGFILE"
        mkdir -p "$RRD_DIR"
        tar -xzf "$BACKUP_DIR/$BACKUP_FILE" -C /
    else
        echo "[$TIMESTAMP] No RRD backup found" >> "$LOGFILE"
    fi
}

start() {
    restore
}

stop() {
    backup
}
